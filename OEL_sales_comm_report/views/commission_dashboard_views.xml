<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Dashboard Form View -->
        <record id="view_commission_dashboard_form" model="ir.ui.view">
            <field name="name">commission.dashboard.form</field>
            <field name="model">commission.dashboard</field>
            <field name="arch" type="xml">
                <form string="Sales Commission Review" create="false" edit="false" delete="false">
                    <sheet>
                        <div class="oe_title">
                            <h1>Sales Commission Review</h1>
                        </div>
                        <group>
                            <p>Click the button below to prepare and view the sales commission report for a specific month.</p>
                        </group>
                        <footer>
                            <button string="Prepare Commission Report" 
                                    type="object" 
                                    name="action_open_wizard" 
                                    class="oe_highlight"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Dashboard Action -->
        <record id="action_commission_dashboard" model="ir.actions.act_window">
            <field name="name">Sales Commission Review</field>
            <field name="res_model">commission.dashboard</field>
            <field name="view_mode">form</field>
            <field name="target">inline</field>
        </record>

        <!-- Main Menu Item -->
        <menuitem id="menu_sales_commission_main"
                  name="Sales Commission Review"
                  parent="account.menu_finance"
                  action="action_commission_dashboard"
                  sequence="50"/>

    </data>
</odoo>
