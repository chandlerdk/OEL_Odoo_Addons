<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="email_template_credit_memo" model="mail.template">
            <field name="name">Credit Memo: Sending</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="subject">Credit Memo {{ object.name }} from {{ object.company_id.name }}</field>
            <field name="partner_to">{{ object.partner_id.id }}</field>
            <field name="email_from">{{ (object.invoice_user_id.email_formatted or object.company_id.email_formatted or user.email_formatted) }}</field>
            <field name="use_default_to" eval="True"/>
            <field name="body_html" type="html">
                <p>Dear <t t-out="object.partner_id.name"/>,</p>
                <p>Please find attached your credit memo <t t-out="object.name"/> for <t t-out="object.amount_total"/> <t t-out="object.currency_id.name"/>.</p>
                <p>This credit memo represents an amount we owe you.</p>
                <p>Thank you for your business.</p>
            </field>
            <field name="lang">{{ object.partner_id.lang }}</field>
        </record>

    </data>
</odoo>
