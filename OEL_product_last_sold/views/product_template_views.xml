<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add field to product form (Sales tab) -->
    <record id="product_template_form_last_sold" model="ir.ui.view">
        <field name="name">product.template.form.last.sold</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales_description']" position="after">
                <page string="Sales Info" name="oel_sales_info">
                    <group>
                        <field name="last_sold_date" readonly="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Add column to product list view -->
    <record id="product_template_list_last_sold" model="ir.ui.view">
        <field name="name">product.template.list.last.sold</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="last_sold_date" optional="show" string="Last Sold"/>
            </xpath>
        </field>
    </record>

</odoo>
