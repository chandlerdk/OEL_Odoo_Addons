<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_account_move_commission_update_wizard" model="ir.ui.view">
        <field name="name">account.move.commission.update.wizard.form</field>
        <field name="model">account.move.commission.update.wizard</field>
        <field name="arch" type="xml">
            <form string="Update Commission">
                <group>
                    <group>
                        <field name="move_id"/>
                        <field name="payment_state"/>
                    </group>
                    <group>
                        <field name="sale_rep_id"/>
                        <field name="has_accrual"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                </group>
                <div class="alert alert-info" role="alert">
                    Change commission percentages below, then Apply.
                    The invoice stays posted/paid; only the commission accrual journal entry is cancelled and recreated.
                    Do not reset the invoice to draft — that would unreconcile the payment.
                </div>
                <field name="line_ids">
                    <tree editable="bottom" create="0" delete="0">
                        <field name="move_line_id" column_invisible="1" force_save="1" readonly="1"/>
                        <field name="name" readonly="1" force_save="1"/>
                        <field name="price_subtotal" readonly="1" sum="Total"/>
                        <field name="epd_paid_on_line" readonly="1" optional="show"/>
                        <field name="commission_percent"/>
                        <field name="in_commission_percent"/>
                        <field name="out_commission_percent"/>
                        <field name="commission_amount" optional="hide"/>
                        <field name="in_commission_amount" optional="hide"/>
                        <field name="out_commission_amount" optional="hide"/>
                        <field name="currency_id" column_invisible="1"/>
                    </tree>
                </field>
                <footer>
                    <button name="action_apply" type="object" string="Apply &amp; Rebuild Accrual" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_account_move_commission_update_wizard" model="ir.actions.act_window">
        <field name="name">Update Commission</field>
        <field name="res_model">account.move.commission.update.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">form</field>
    </record>
</odoo>
