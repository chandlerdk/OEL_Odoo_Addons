<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_visibility" model="ir.ui.view">
        <field name="name">product.template.form.visibility</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales']" position="inside">
                <group string="Customer Visibility Rules">
                    <field name="enable_customer_visibility_rules"/>
                    <field name="allowed_partner_ids" widget="many2many_tags"
                           invisible="not enable_customer_visibility_rules"/>
                    <field name="disallowed_partner_ids" widget="many2many_tags"
                           invisible="not enable_customer_visibility_rules"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
