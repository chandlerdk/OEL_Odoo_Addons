<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_visibility" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.visibility</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/tree//field[@name='product_template_id']" position="attributes">
                <attribute name="context">
                    {'partner_id': parent.partner_id, 'sale_order_partner_id': parent.partner_id, 'default_sale_ok': 1}
                </attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']/tree//field[@name='product_id']" position="attributes">
                <attribute name="context">
                    {'partner_id': parent.partner_id, 'sale_order_partner_id': parent.partner_id}
                </attribute>
            </xpath>
        </field>
    </record>
</odoo>
